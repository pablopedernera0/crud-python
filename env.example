# ── MySQL ─────────────────────────────────────────────────────────────────────
MYSQL_HOST=172.18.0.2
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=mysecretpassword
MYSQL_DATABASE=alumnos

# ── S3 / Floci ────────────────────────────────────────────────────────────────
# Endpoint del emulador Floci (reemplazar con la IP real del servidor)
S3_ENDPOINT=http://localhost:4566
S3_REGION=us-east-1
S3_BUCKET=fotos-alumnos

# Credenciales IAM (el alumno las genera en el Paso 2)
AWS_ACCESS_KEY_ID=REEMPLAZAR_CON_TU_ACCESS_KEY
AWS_SECRET_ACCESS_KEY=REEMPLAZAR_CON_TU_SECRET_KEY
